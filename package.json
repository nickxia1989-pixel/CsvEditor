{
  "name": "new-csv-editor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "start:editor": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-editor.ps1",
    "stop:editor": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-editor.ps1",
    "build": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit && vite build",
    "desktop": "npm run build && electron .",
    "desktop:smoke": "node scripts/desktop-smoke.cjs",
    "dist:desktop": "npm run build && node scripts/package-desktop.cjs",
    "check:tables": "node scripts/check-tables.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^0.555.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "@types/papaparse": "^5.3.16",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "electron": "^42.3.3",
    "jsdom": "^27.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.14"
  }
}
